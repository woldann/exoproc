# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output
*.lcov

# Build outputs
**/dist/
**/deps/
build/
*.tsbuildinfo
# Per-package LICENSE copies (generated by scripts/build.ts at build time)
packages/*/LICENSE
# Bundled example client UIs + shared stylesheet (generated by
# scripts/build.ts at build time)
examples/*/client.js
examples/*/client.js.map
examples/kit/styles.generated.css
examples/kit/styles.generated.css.map

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Environment
.env
.env.local
.env.*.local
# tests/.env is committed on purpose -- non-secret test defaults
# (EXOPROC_LOG_LEVEL/EXOPROC_LOG_DIR) that tests/setup.ts expects to exist.
!tests/.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/

# Linting
.eslintcache
