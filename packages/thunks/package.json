{
  "name": "bun-thunks",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Hand-assembled x64 Win64-calling-convention machine code thunks for Bun — call arbitrary function pointers with dynamic argument lists without a remote trampoline.",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "exoproc",
    "machinecode",
    "thunk",
    "windows",
    "x64",
    "win64",
    "calling-convention",
    "ffi"
  ],
  "author": "Serkan",
  "homepage": "https://github.com/woldann/exoproc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woldann/exoproc.git"
  },
  "bugs": {
    "url": "https://github.com/woldann/exoproc/issues"
  },
  "dependencies": {
    "bun-xffi": "workspace:*"
  }
}
