{
  "name": "bun-capstone",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "TypeScript/FFI bindings for the Capstone disassembly engine with full OOP support",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.11"
  },
  "files": [
    "dist",
    "deps",
    "LICENSE"
  ],
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "capstone",
    "disassembler",
    "disassembly",
    "x86",
    "x86_64",
    "reverse-engineering",
    "binary-analysis",
    "ffi",
    "typescript",
    "exoproc",
    "win32",
    "windows"
  ],
  "author": "Serkan",
  "homepage": "https://github.com/woldann/exoproc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woldann/exoproc.git"
  },
  "bugs": {
    "url": "https://github.com/woldann/exoproc/issues"
  },
  "dependencies": {
    "bun-xffi": "workspace:*"
  }
}
