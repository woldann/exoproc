{
  "name": "bun-relay",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Transport-agnostic UDP call/notification relay for Bun — a single well-known loopback port that any package can register an opcode against.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "exoproc",
    "udp",
    "relay",
    "rpc",
    "ipc",
    "windows",
    "x64"
  ],
  "author": "Serkan",
  "homepage": "https://github.com/woldann/exoproc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woldann/exoproc.git"
  },
  "bugs": {
    "url": "https://github.com/woldann/exoproc/issues"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {
    "exoproc-utils": "workspace:*"
  }
}
