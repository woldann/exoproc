{
  "name": "exoproc-dummy",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "A single shared, long-lived dummy Windows process (default: ping.exe) other exoproc packages and tests spawn once and reuse as a lightweight cross-process target.",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.11"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "exoproc",
    "windows",
    "x64",
    "native",
    "cross-process",
    "systems-instrumentation",
    "testing"
  ],
  "author": "Serkan",
  "homepage": "https://github.com/woldann/exoproc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woldann/exoproc.git"
  },
  "bugs": {
    "url": "https://github.com/woldann/exoproc/issues"
  },
  "dependencies": {
    "bun-xffi": "workspace:*"
  }
}
