{
  "name": "bun-nevent",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Cross-process Windows event (CreateEventA) handle relay for Bun via a dummy-process handle relay — the caller never OpenProcess's the target directly.",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.11"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "exoproc",
    "event",
    "windows",
    "x64",
    "native",
    "handle-relay",
    "cross-process",
    "systems-instrumentation"
  ],
  "author": "Serkan",
  "homepage": "https://github.com/woldann/exoproc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woldann/exoproc.git"
  },
  "bugs": {
    "url": "https://github.com/woldann/exoproc/issues"
  },
  "dependencies": {
    "bun-xffi": "workspace:*",
    "exoproc-dummy": "workspace:*",
    "exoproc-utils": "workspace:*"
  }
}
