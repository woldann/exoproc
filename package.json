{
  "name": "exoproc-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript toolkit for Windows x64 native systems programming, memory manipulation, and process instrumentation.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "keywords": [
    "exoproc",
    "monorepo",
    "windows",
    "x64",
    "native",
    "systems-programming",
    "instrumentation",
    "assembler",
    "disassembler",
    "memory-manipulation"
  ],
  "author": "Serkan",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woldann/exoproc.git"
  },
  "bugs": {
    "url": "https://github.com/woldann/exoproc/issues"
  },
  "homepage": "https://github.com/woldann/exoproc#readme",
  "engines": {
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11",
  "bin": {
    "bun-wine": "./bun-wine"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:clean": "bun run clean && bun run build",
    "clean": "find . -name dist -type d -not -path '*/node_modules/*' -exec rm -rf {} + 2>/dev/null; find . -name '*.tsbuildinfo' -not -path '*/node_modules/*' -delete 2>/dev/null; true",
    "download-deps": "bun scripts/download-deps.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\" \"examples/**/*.tsx\" --cache",
    "lint:fix": "eslint \"packages/*/src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\" \"examples/**/*.tsx\" --cache --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "bun x tsc --noEmit -p tests/tsconfig.json",
    "prepare": "husky",
    "postinstall": "bun run download-deps",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "dotenv": "^16.6.1",
    "winston": "^3.19.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^8.57.0",
    "@types/bun": "latest",
    "chalk": "^5.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^14.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "~5.5.4",
    "typescript-eslint": "^7.0.2",
    "unzipper": "^0.12.3"
  }
}
